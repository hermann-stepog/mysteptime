# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# TLS das chamadas server-side ao Supabase (somente servidor — NÃO usar prefixo VITE_)
# Preferencial em produção: apontar para a CA corporativa (mantém rejectUnauthorized=true).
SUPABASE_CA_CERT_PATH=
# Fallback controlado para ambiente corporativo autorizado (não afeta Drake nem outras integrações).
SUPABASE_IGNORE_HTTPS_ERRORS=false

# Bypass exclusivo de desenvolvimento (NUNCA em produção)
DRAKE_DEV_BYPASS_APP_AUTH=false
DRAKE_DEV_TRIGGERED_BY=local-development
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Smartsheet / SMTP (existentes)
SMARTSHEET_TOKEN=
SMARTSHEET_SHEET_ID=
VITE_SMARTSHEET_TOKEN=
VITE_SMARTSHEET_SHEET_ID=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Drake HTTP (somente servidor — NÃO usar prefixo VITE_/NEXT_PUBLIC_/REACT_APP_)
DRAKE_USERNAME=
DRAKE_PASSWORD=
DRAKE_DISCOVERY_RAW_PATH=
DRAKE_BASE_URL=https://drake.bz
DRAKE_TIMEZONE=America/Sao_Paulo
DRAKE_IGNORE_HTTPS_ERRORS=false
DRAKE_EXPORT_TIMEOUT_MS=600000
DRAKE_INITIAL_JOB_APPEAR_TIMEOUT_MS=30000
DRAKE_EMPTY_JOB_POLLS_BEFORE_FALLBACK=3
DRAKE_EMPTY_JOB_POLLS_BEFORE_FAILURE=15
DRAKE_POLL_INTERVAL_MS=2000
DRAKE_KEEP_TEMP_FILES=false
DRAKE_DIAGNOSTICS_ENABLED=false
DRAKE_KEEP_DIAGNOSTICS_ON_ERROR=false
DRAKE_TEMP_MAX_AGE_MINUTES=60
DRAKE_AUTH_HEADLESS=true
DRAKE_SESSION_CACHE_ENABLED=true
DRAKE_SESSION_CACHE_PATH=./private/drake/storage-state.json
DRAKE_CONTEXT_NAME=Step
# Vazio = tmpdir do SO (mysteptime-drake). Não usar a pasta do projeto.
DRAKE_TEMP_DIR=
# Opcional: diretório fixo do último erro (sobrescreve o anterior).
DRAKE_LAST_DIAGNOSTIC_DIR=
DRAKE_LOG_LEVEL=info
DRAKE_DEBUG_HTTP=false
DRAKE_DEBUG_POLLING=true
DRAKE_LAST_ERROR_FILE_ENABLED=true
DRAKE_JOB_CLOCK_SKEW_MS=30000
DRAKE_EXPORT_MAX_ATTEMPTS=2
DRAKE_DISCOVERY_RAW_PATH=
DRAKE_BACKGROUND_SUCCESS_STATUSES=
DRAKE_BACKGROUND_FAILURE_STATUSES=
